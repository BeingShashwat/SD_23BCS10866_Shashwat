        <mxCell id="CT0OThE3xNQgopTQ5EQj-1" parent="1" style="whiteSpace=wrap;html=1;" value="DESIGN AN INSTAGRAM LIKE SYSTEM WITH FOLLOWING REQUIREMENTS:&lt;div&gt;1. USER LOGIN SERVICE&lt;/div&gt;&lt;div&gt;2. CONTENT SERVCIE&lt;/div&gt;&lt;div&gt;3. FEED SERVICE&lt;/div&gt;&lt;div&gt;4. FOLLOWER SERVICE&lt;/div&gt;&lt;div&gt;5. USER ENGAGEMENT SERVICE&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;IMPLEMENT A MECHANISM TO RESTRICT THE USER POLICY FOR POSTING A NON POLICY COMPLIANT POST.&lt;/div&gt;&lt;div&gt;OPTIMIZE THE DYNAMIC FEED GENERATION&lt;/div&gt;&lt;div&gt;HIGHLIGHT THE USE OF BACKFILL SERVICE&lt;/div&gt;" vertex="1">
          <mxGeometry height="170" width="760" x="30" y="60" as="geometry" />
        </mxCell>
        <mxCell id="CT0OThE3xNQgopTQ5EQj-2" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;autosize=1;resizable=0;" value="&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;FUNCTIONAL REQUIREMENTS:&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;1. LOGIN SIGNUP SERVICE&lt;/div&gt;&lt;div&gt;2. CONTENT SERVICE (POSTS)&lt;/div&gt;&lt;div&gt;3. FEED (VIEWING POSTS)&lt;/div&gt;&lt;div&gt;4.USER ENGAGEMENT SERVICE(LIKES AND COMMENTS)&lt;/div&gt;&lt;div&gt;5. MAINTAINING USER POLICY FOR POSTING&lt;/div&gt;" vertex="1">
          <mxGeometry height="110" width="350" x="40" y="260" as="geometry" />
        </mxCell>
        <mxCell id="CT0OThE3xNQgopTQ5EQj-3" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;autosize=1;resizable=0;" value="NONFUNCTIONAL REQUIREMENTS:&lt;div&gt;&lt;br&gt;&lt;div&gt;1. AVAILABILITY &amp;gt;&amp;gt;&amp;gt; CONSISTENCY&lt;/div&gt;&lt;div&gt;2. 1M DAILY USERS&lt;/div&gt;&lt;div&gt;3. 500 MS LATENCY(ALL COMBINED-&amp;gt; DB FETCH, SERVER CALLS)&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="90" width="400" x="40" y="410" as="geometry" />
        </mxCell>
        <mxCell id="CT0OThE3xNQgopTQ5EQj-4" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;autosize=1;resizable=0;" value="API DESIGN:&lt;div&gt;1. GET : HTTP GET CALL TO FOR VIEWING POSTS&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;2. POST:&lt;/div&gt;&lt;div&gt;HTTP POST CALL FOR POSTING CONTENT&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="110" width="310" x="40" y="540" as="geometry" />
        </mxCell>
        <mxCell id="CT0OThE3xNQgopTQ5EQj-5" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;autosize=1;resizable=0;" value="DB DESIGN:&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;1. USER DB (user_id, username, followers, following)&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;2. POSTS DB (post_id, metadata)&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;3. COMMENTS DB&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;4. LIKE DB&lt;/div&gt;" vertex="1">
